SECRET_KEY=replace-with-a-long-random-secret
FLASK_DEBUG=0
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5000

# Railway MySQL: use either MYSQL_URL/DATABASE_URL or the individual values below.
MYSQL_URL=
DATABASE_URL=
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DB=
MYSQL_CONNECT_TIMEOUT=10
MYSQL_SSL_MODE=

# Frontend origin(s) allowed to call the backend.
# Example: https://your-frontend.vercel.app
FRONTEND_ORIGIN=
CORS_ALLOWED_ORIGINS=
