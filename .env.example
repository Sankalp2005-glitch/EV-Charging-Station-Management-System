# Copy this file to `.env` in the repository root. The backend loads `.env` automatically in local development.
APP_ENV=development
SECRET_KEY=replace-with-a-long-random-secret
FLASK_DEBUG=0
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5000

# Railway MySQL: use either MYSQL_URL/DATABASE_URL or the individual values below.
MYSQL_URL=
DATABASE_URL=
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DB=
MYSQL_CONNECT_TIMEOUT=10
MYSQL_SSL_MODE=

# Frontend origin(s) allowed to call the backend.
# Example: https://your-frontend.vercel.app
FRONTEND_ORIGIN=
CORS_ALLOWED_ORIGINS=

# Optional support email delivery for customer/owner help requests.
SUPPORT_ADMIN_EMAIL=
SUPPORT_FROM_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=1
SMTP_USE_SSL=0
SMTP_TIMEOUT=15
